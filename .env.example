# Copy to .env and fill in. .env is gitignored.
DB_PASSWORD=change-me-openssl-rand-hex-24
DB_HOST=timescaledb
DB_PORT=5432
DB_NAME=quant
DB_USER=quant

# Alpaca paper credentials (live keys not created until Phase 6)
MODE=paper
ALPACA_KEY_ID=your-paper-key-id
ALPACA_SECRET_KEY=your-paper-secret
ALPACA_TRADING_URL=https://paper-api.alpaca.markets
ALPACA_DATA_FEED=sip

# Host user the dashboard container runs AS, so files it writes into the ~/.quant-ops bind-mount
# (the hourly status board JSON) stay host-owned and the host Lead loop can also write them. Set to
# `id -u`:`id -g` of the box's primary user. Defaults to 1000:1000 in docker-compose.yml if unset.
HOST_UID=1000
HOST_GID=1000

