{
  "uid": "feature-latency",
  "title": "Feature compute latency (per group)",
  "tags": ["features", "latency"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "p99 compute time per group (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "1000 * histogram_quantile(0.99, sum by (le, group) (rate(feature_group_compute_seconds_bucket[5m])))",
          "legendFormat": "{{group}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "p50 compute time per group (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "1000 * histogram_quantile(0.50, sum by (le, group) (rate(feature_group_compute_seconds_bucket[5m])))",
          "legendFormat": "{{group}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Slowest groups now — p99 (ms), ranked",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sort_desc(1000 * histogram_quantile(0.99, sum by (le, group) (rate(feature_group_compute_seconds_bucket[5m]))))",
          "format": "table",
          "instant": true,
          "legendFormat": "{{group}}"
        }
      ]
    }
  ]
}
