{
  "uid": "bar-to-vector-latency",
  "title": "Bar -> vector latency (end-to-end + drill-down)",
  "tags": ["features", "latency", "bar-to-vector"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Bar -> vector p50/p95/p99 — OVERALL (first-bar anchor, end-to-end incl. Alpaca delivery)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "p50",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(feature_vector_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "refId": "p95",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(feature_vector_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "refId": "p99",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(feature_vector_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 2,
      "title": "Bar -> vector p99 PER SHARD (spot a hot shard)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(feature_vector_latency_seconds_bucket[5m])) by (le, shard))",
          "legendFormat": "shard {{shard}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Assemble p50/p95/p99 — PURE COMPUTE (last-bar anchor, excludes Alpaca delivery spread)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "p50",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(feature_assemble_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "refId": "p95",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(feature_assemble_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "refId": "p99",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(feature_assemble_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "title": "Feature group compute p99 (ms) — secondary",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 27 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "1000 * histogram_quantile(0.99, sum by (le, group) (rate(feature_group_compute_seconds_bucket[5m])))",
          "legendFormat": "{{group}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Slowest tickers (last 30m) — drill-down: arrival_lag_s = Alpaca-late, total_latency_s = ours",
      "type": "table",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 36 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT minute, shard, symbol, arrival_lag_s, total_latency_s FROM latency_slow_symbols WHERE minute > now() - interval '30 minutes' ORDER BY total_latency_s DESC LIMIT 200"
        }
      ]
    }
  ]
}
